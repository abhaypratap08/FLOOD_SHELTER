{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "15mb"
      }
    }
  ],
  "env": {
    "FLASK_ENV": "production",
    "FLASK_APP": "app.py"
  },
  "installCommand": "pip install -r requirements.txt",
  "buildCommand": "flask db upgrade"
}
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ]
}
